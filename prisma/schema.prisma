generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id                   String    @id @default(uuid()) @db.Uuid // Matches Supabase auth.users id
  displayName          String?
  avatarUrl            String?
  timezone             String    @default("UTC")
  hoursPerWeekGoal     Int       @default(5)
  onboardingCompleted  Boolean   @default(false)
  lastActiveAt         DateTime?
  currentStreak        Int       @default(0)
  longestStreak        Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  roadmaps          Roadmap[]
  quizAttempts      QuizAttempt[]
  weaknessLogs      WeaknessLog[]
  reviewQueue       ReviewQueue[]
  dailyPlans        DailyPlan[]
  userAchievements  UserAchievement[]
  savedResources    SavedResource[]
  studyGroups       StudyGroupMember[]
  publicProfile     CommunityPublicProfile?
}

model Roadmap {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  title       String
  goalText    String
  timeline    Int      // in weeks
  skillLevel  String
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, ARCHIVED
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks       RoadmapWeek[]

  @@index([userId])
}

model RoadmapWeek {
  id          String   @id @default(cuid())
  roadmapId   String
  weekNumber  Int
  theme       String
  status      String   @default("LOCKED") // LOCKED, AVAILABLE, IN_PROGRESS, COMPLETED
  unlockDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmap     Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@index([roadmapId])
}

model Lesson {
  id             String   @id @default(cuid())
  weekId         String
  title          String
  description    String?
  estimatedMins  Int      @default(30)
  position       Int
  status         String   @default("LOCKED") // LOCKED, AVAILABLE, IN_PROGRESS, PASSED, MASTERED, NEEDS_RETRY
  completedAt    DateTime?
  masteryLevel   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  week           RoadmapWeek  @relation(fields: [weekId], references: [id], onDelete: Cascade)
  resources      Resource[]
  quizQuestions  QuizQuestion[]
  quizAttempts   QuizAttempt[]
  reviewQueue    ReviewQueue[]

  @@index([weekId])
}

model Resource {
  id              String   @id @default(cuid())
  lessonId        String
  title           String
  url             String
  type            String   // VIDEO, ARTICLE, COURSE, BOOK, PROJECT, DOCUMENTATION
  platform        String
  isPaid          Boolean  @default(false)
  durationMins    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson          Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  savedResources  SavedResource[]

  @@index([lessonId])
}

model QuizQuestion {
  id           String   @id @default(cuid())
  lessonId     String
  questionText String
  questionType String   @default("MULTIPLE_CHOICE")
  options      Json     // Array of options with isCorrect flag
  explanation  String
  conceptTag   String
  difficulty   Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  userId       String   @db.Uuid
  lessonId     String
  score        Float
  answers      Json     // Array of submitted answers
  timeTaken    Int      // in seconds
  result       String   // FAILED, PASSED, MASTERED
  createdAt    DateTime @default(now())

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
}

model WeaknessLog {
  id              String    @id @default(cuid())
  userId          String    @db.Uuid
  conceptTag      String
  failureCount    Int       @default(1)
  isDeepWeakness  Boolean   @default(false)
  lastFailedAt    DateTime  @default(now())
  nextReviewAt    DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, conceptTag])
}

model ReviewQueue {
  id           String    @id @default(cuid())
  userId       String    @db.Uuid
  lessonId     String
  reviewType   String    // WEAKNESS, MASTERY_REFRESH
  scheduledFor DateTime
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
}

model DailyPlan {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  date        DateTime @db.Date
  items       Json     // Array of plan items
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model Achievement {
  id          String   @id @default(cuid())
  tier        String   // CONSISTENCY, MASTERY, COMPLETION
  name        String
  description String
  iconUrl     String?
  kudosCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @db.Uuid
  achievementId String
  earnedAt      DateTime @default(now())

  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([achievementId])
}

model CommunityPublicProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @db.Uuid
  handle      String   @unique
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudyGroup {
  id          String   @id @default(cuid())
  name        String
  topic       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     StudyGroupMember[]
}

model StudyGroupMember {
  id           String   @id @default(cuid())
  groupId      String
  userId       String   @db.Uuid
  joinedAt     DateTime @default(now())

  group        StudyGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
}

model SavedResource {
  id           String   @id @default(cuid())
  userId       String   @db.Uuid
  resourceId   String
  savedAt      DateTime @default(now())

  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource     Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
}
